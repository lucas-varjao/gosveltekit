SERVER_PORT=8080
DATABASE_DSN=postgresql://gosvelte:gosvelte@localhost:5432/gosveltekit?sslmode=disable
AUTH_SESSION_TTL=720h
AUTH_REFRESH_THRESHOLD=360h
